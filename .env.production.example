# ===== Runtime =====
NODE_ENV="production"
PORT="4000"

# ===== Database =====
DATABASE_URL="<YOUR_PRODUCTION_DATABASE_URL>"

# ===== Frontend / CORS =====
# Multiple origins allowed, separated by comma.
CORS_ORIGIN="https://www.yourstore.com"

# ===== Auth / Security =====
JWT_SECRET="<GENERATE_A_LONG_RANDOM_SECRET>"
PII_HASH_SECRET="<GENERATE_ANOTHER_LONG_RANDOM_SECRET>"

# ===== Admin =====
ADMIN_EMAIL="<YOUR_ADMIN_EMAIL>"
ADMIN_PASSWORD="<SET_A_STRONG_PASSWORD>"

# ===== Square Production =====
SQUARE_ENV="production"
SQUARE_ACCESS_TOKEN="<SQUARE_PRODUCTION_ACCESS_TOKEN>"
SQUARE_LOCATION_ID="<SQUARE_PRODUCTION_LOCATION_ID>"
SQUARE_VERSION="2026-01-22"

# Redirect users back to your site after Square checkout.
CHECKOUT_RETURN_BASE_URL="https://www.yourstore.com"

# Webhook URL must be public HTTPS and exactly match Square dashboard config.
SQUARE_WEBHOOK_SIGNATURE_KEY="<SQUARE_WEBHOOK_SIGNATURE_KEY>"
SQUARE_WEBHOOK_NOTIFICATION_URL="https://www.yourstore.com/api/orders/square/webhook"

# ===== Resend (Email Verification) =====
PUBLIC_SITE_URL="https://www.yourstore.com"
RESEND_API_KEY="<YOUR_RESEND_API_KEY>"
RESEND_FROM_EMAIL="no-reply@yourstore.com"
RESEND_FROM_NAME="Luxury Cloth Inc."
RESEND_API_BASE_URL="https://api.resend.com"

# ===== Translation (Machine FR) =====
# Free fallback (no paid API key required):
MYMEMORY_TRANSLATE_ENABLED="true"
MYMEMORY_CONTACT_EMAIL="namekuok@gmail.com"
# Optional paid providers (higher stability / quality):
GOOGLE_TRANSLATE_API_KEY=""
LIBRETRANSLATE_URL=""
LIBRETRANSLATE_API_KEY=""

# ===== Interac e-transfer monitor (Gmail IMAP) =====
ETRANSFER_MONITOR_ENABLED="false"
ETRANSFER_RECEIVER_EMAIL="payments@yourstore.com"
ETRANSFER_MONITOR_INTERVAL_MS="1000"
GMAIL_IMAP_HOST="imap.gmail.com"
GMAIL_IMAP_PORT="993"
GMAIL_IMAP_MAILBOX="INBOX"
GMAIL_IMAP_USER="<YOUR_GMAIL_INBOX>"
GMAIL_IMAP_PASSWORD="<YOUR_GMAIL_APP_PASSWORD>"
GMAIL_ETRANSFER_FROM="notify@payments.interac.ca"
GMAIL_ETRANSFER_KEYWORD="interac"
GMAIL_ETRANSFER_SCAN_LIMIT="30"
