DATABASE_URL="file:./dev.db"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="replace-with-strong-secret"
PII_HASH_SECRET="replace-with-another-strong-secret"
ADMIN_EMAIL="namekuok@gmail.com"
ADMIN_PASSWORD="admin123"
SQUARE_ENV="production"
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
SQUARE_VERSION="2026-01-22"
CHECKOUT_RETURN_BASE_URL="http://localhost:4000"
SQUARE_WEBHOOK_SIGNATURE_KEY=""
SQUARE_WEBHOOK_NOTIFICATION_URL="http://localhost:4000/api/orders/square/webhook"

# Interac e-transfer monitor (Gmail IMAP)
ETRANSFER_MONITOR_ENABLED="false"
ETRANSFER_RECEIVER_EMAIL=""
ETRANSFER_MONITOR_INTERVAL_MS="1000"
GMAIL_IMAP_HOST="imap.gmail.com"
GMAIL_IMAP_PORT="993"
GMAIL_IMAP_MAILBOX="INBOX"
GMAIL_IMAP_USER=""
GMAIL_IMAP_PASSWORD=""
GMAIL_ETRANSFER_FROM=""
GMAIL_ETRANSFER_KEYWORD="interac"
GMAIL_ETRANSFER_SCAN_LIMIT="30"

# Resend email verification
PUBLIC_SITE_URL="http://localhost:4000"
RESEND_API_KEY=""
RESEND_FROM_EMAIL=""
RESEND_FROM_NAME="Luxury Cloth Inc."
# Optional override (default is https://api.resend.com)
RESEND_API_BASE_URL="https://api.resend.com"

# Choose one translation provider:
# 1) Google Cloud Translation API:
GOOGLE_TRANSLATE_API_KEY=""
# 2) LibreTranslate:
LIBRETRANSLATE_URL=""
LIBRETRANSLATE_API_KEY=""
# 3) Free fallback (MyMemory) - recommended for small traffic:
MYMEMORY_TRANSLATE_ENABLED="true"
# Optional contact email for better public quota behavior:
MYMEMORY_CONTACT_EMAIL="namekuok@gmail.com"
