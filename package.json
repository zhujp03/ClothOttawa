{
  "name": "nimbus-athletica-node",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch app.js",
    "start": "node app.js",
    "setup": "cp -n .env.example .env || true && npm install && npm run prisma:generate && npm run prisma:migrate -- --name init && npm run prisma:seed",
    "prisma:generate": "prisma generate --schema database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema database/schema.prisma",
    "prisma:seed": "node database/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.8",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
